# Copia este archivo a backend/.env y rellena tu clave real de Groq.
# NUNCA comites backend/.env al repositorio (ya está en .gitignore).
GROQ_API_KEY=gsk_REEMPLAZAR_POR_TU_CLAVE
GROQ_MODEL=llama-3.3-70b-versatile
PORT=3000
DEBUG_INTERPRETAR=false
# HITO S1: logs de performance del backend ([Iky][perf]) en stdout.
DEBUG_PERF=false

# ElevenLabs TTS (opcional). Si API_KEY o VOICE_ID quedan vacíos, el
# frontend cae automáticamente a Web Speech API del navegador.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
